rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'createdAt']) &&
             data.keys().size() >= 3 && data.keys().size() <= 5 &&
             data.uid is string &&
             data.uid == request.auth.uid &&
             data.displayName is string &&
             data.displayName.size() <= 100 &&
             data.createdAt is string &&
             (!('email' in data) || data.email == null || (data.email is string && data.email.size() <= 150)) &&
             (!('lastActiveAt' in data) || data.lastActiveAt == null || data.lastActiveAt is string);
    }

    // Match users profiles
    match /users/{userId} {
      allow get: if true;
      allow list: if true;
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'email', 'lastActiveAt']);
      allow delete: if false;
    }

    // Match Incidents
    match /incidents/{incidentId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    // Match comments
    match /comments/{commentId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // Match votes
    match /votes/{voteId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // Match reported problems
    match /problems/{problemId} {
      allow create: if isSignedIn() && isValidId(problemId);
      allow read: if isSignedIn() && request.auth.token.email == "ayaanamaan23@gmail.com";
      allow update, delete: if false;
    }
  }
}
